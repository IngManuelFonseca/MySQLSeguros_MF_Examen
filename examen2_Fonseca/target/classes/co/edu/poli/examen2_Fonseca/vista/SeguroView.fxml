<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="co.edu.poli.examen2_Fonseca.controlador.SeguroController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Gestión de Seguros - Fonseca" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <Label text="Número:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtNumero" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Fecha (aaaa-mm-dd):" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txtFecha" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Estado:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="cbEstado" prefWidth="150" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="ID Asegurado:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="txtIdAsegurado" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Nombre Asegurado:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="txtNombreAsegurado" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
    </GridPane>

    <HBox spacing="15" alignment="CENTER">
        <Button text="Guardar Seguro Vida" onAction="#guardarVida"/>
        <Button text="Guardar Seguro Vehículo" onAction="#guardarVehiculo"/>
    </HBox>

    <TableView fx:id="tablaSeguros" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNumero" text="Número" prefWidth="80"/>
            <TableColumn fx:id="colFecha" text="Fecha" prefWidth="100"/>
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="80"/>
            <TableColumn fx:id="colId" text="ID Asegurado" prefWidth="100"/>
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="150"/>
        </columns>
    </TableView>
</VBox>